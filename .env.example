# JarbiX Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# Always start in paper mode until you've verified everything works.
PAPER_TRADE=true

# Hyperliquid leverage cap (max the exchange allows is 50x; we default 50x)
MAX_LEVERAGE_HYPERLIQUID=50.0
MAX_LEVERAGE_PAPER=50.0

# Risk controls — conservative defaults, think hard before changing
MAX_LOSS_PCT=0.02               # Stop a trade at 2% loss
MAX_POSITION_SIZE_PCT=0.05      # Never risk more than 5% of portfolio per trade
MAX_CONCURRENT_TRADES=4
MAX_DAILY_TRADES=12
POSITION_TIMEOUT_MINUTES=30

# iOS companion API port
FLASK_PORT=5000
SECRET_KEY=change_this_to_a_strong_random_string_in_production

# Hyperliquid live-trading credentials (leave blank for paper mode)
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=
