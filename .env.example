# JarbiX Configuration - Start with PAPER_TRADE=true for safety!

COMPLIANT_MODE=true
PAPER_TRADE=true

# Broker selection (use 'auto' for best-trade routing)
PRIMARY_BROKER=auto

# Maximum legal leverage per platform (do NOT exceed these)
MAX_LEVERAGE_COINBASE=10.0
MAX_LEVERAGE_BITNOMIAL=6.0
MAX_LEVERAGE_KRAKEN_US=10.0
MAX_LEVERAGE_CME=15.0

# Risk controls (conservative defaults)
MAX_LOSS_PCT=0.02
MAX_POSITION_SIZE_PCT=0.05
MAX_CONCURRENT_TRADES=4
POSITION_TIMEOUT_MINUTES=30

# Webhook / Dashboard settings
FLASK_PORT=5000
SECRET_KEY=change_this_to_a_strong_random_string_in_production

# Add your real API keys here ONLY when ready for live trading on one platform at a time
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# etc.